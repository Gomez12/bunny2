{
  "name": "bunny2",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Internal agent tool — layered, AI-enhanced, event-sourced.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test",
    "build": "bun run --filter '*' build",
    "dev:server": "bun run --filter '@bunny2/server' dev",
    "dev:web": "bun run --filter '@bunny2/web' dev",
    "dev:desktop": "bun run --filter '@bunny2/desktop' dev",
    "package": "echo 'package script is implemented in phase 1.6' && exit 0",
    "docs:check": "bun run scripts/docs-check.ts",
    "i18n:check": "echo 'i18n:check is implemented in phase 1.5' && exit 0"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/bun": "latest",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.5.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
